# Copy this file to .env and fill in your keys
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: real OTP email delivery via Gmail SMTP.
# Leave blank to keep demo mode (OTP prints to the backend terminal instead).
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Auth cookie security. Leave unset (or "false") for local development —
# browsers silently drop Secure cookies over plain http, which would break
# login entirely on localhost. On Render, set this to "true".
COOKIE_SECURE=false
